/**
 * Trust marquee — infinite horizontal scroll of app icons in iOS-style cards.
 *
 * Per CLAUDE.md §8: 92×92 cards, radius 22-24, brand bg + inline SVG.
 * The marquee duplicates the apps array so the loop seams perfectly.
 *
 * Note (CLAUDE.md §9): brand SVGs are descriptive use ("works in any app
 * where you can type"). Low takedown risk for an indie app.
 */

interface AppLogo {
  name: string;
  /** CSS background — solid color or gradient string. */
  bg: string;
  /** Inline SVG markup (set via set:html). */
  svg: string;
}

