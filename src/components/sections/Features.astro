---
/**
 * Features grid — 3×2 cards highlighting Ditto's core differentiators.
 *
 * Icons are inline SVGs at stroke 1.4. Hover lifts each card 2px with
 * a stronger shadow.
 */
import SectionTag from "../ui/SectionTag.astro";

const features = [
  {
    icon: '<path d="M8 2l5 1.5v4.5c0 3-2 5-5 6-3-1-5-3-5-6V3.5L8 2z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><path d="M6 8l1.5 1.5L10 7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>',
    title: "100% local",
    desc: "Whisper runs on your machine. Your audio never touches a server.",
  },
  {
    icon: '<path d="M9 2L4 9h3l-1 5 5-7H8l1-5z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>',
    title: "GPU accelerated",
    desc: "CUDA support for NVIDIA GPUs. Transcribes in real time.",
  },
  {
    icon: '<rect x="2.5" y="4.5" width="11" height="7" rx="3.5" stroke="currentColor" stroke-width="1.4"/>',
    title: "5 themes",
    desc: "From minimal matte to colorful aurora gradients. Pick your vibe.",
  },
  {
    icon: '<circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.4"/><path d="M2.5 8h11M8 2.5c2 1.7 2 9.8 0 11.5M8 2.5c-2 1.7-2 9.8 0 11.5" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>',
    title: "100+ languages",
    desc: "Whisper supports 100+ languages out of the box. Auto-detect or fix one.",
  },
  {
    icon: '<rect x="2.5" y="4" width="11" height="8" rx="1.5" stroke="currentColor" stroke-width="1.4"/><path d="M5 7h1M7.5 7h1M10 7h1M5 10h6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>',
    title: "Custom shortcut",
    desc: "Pick any combo. Push-to-talk or toggle, your choice.",
  },
  {
    icon: '<path d="M11 3.5l-5 5-2.5-2.5M11 8.5l-5 5L3.5 11" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>',
    title: "Auto-paste",
    desc: "No extra clicks. Text appears where your cursor was.",
  },
];
---

<section class="page-section">
  <div class="section-head">
    <SectionTag>Features</SectionTag>
    <h2 class="section-title">
      Built for the way <span class="display-italic">you work.</span>
    </h2>
    <p class="section-subtitle">Local processing, blazing fast, and out of your way.</p>
  </div>

  <div class="features-grid">
    {
      features.map((f) => (
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none" set:html={f.icon} aria-hidden="true" />
          </div>
          <div class="feature-title">{f.title}</div>
          <div class="feature-desc">{f.desc}</div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .feature-card {
    background: var(--color-surface);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 28px;
    box-shadow: var(--shadow-xs);
    transition: all 200ms ease-out;
  }
  .feature-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
  }
  .feature-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: var(--color-surface-alt);
    border: 0.5px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 18px;
  }
  .feature-title {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin-bottom: 6px;
  }
  .feature-desc {
    font-size: 13px;
    color: var(--color-text-secondary);
    line-height: 1.55;
  }

  @media (max-width: 900px) {
    .features-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 700px) {
    .features-grid {
      grid-template-columns: 1fr;
      gap: 12px;
    }
    .feature-card { padding: 24px 20px; }
  }
</style>
