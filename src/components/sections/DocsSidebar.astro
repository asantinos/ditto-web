---
/**
 * Docs sidebar — search + grouped nav list.
 *
 * Desktop: 240px column on the left of the docs layout, sticky.
 * Mobile (≤900): collapses to a sticky bar at top with the search and
 * the current page name + chevron. Tapping the trigger expands a popover
 * with all sections (overlays content; doesn't push it).
 */
import type { CollectionEntry } from "astro:content";

interface Props {
  /** All docs in the collection, used to build the grouped nav. */
  docs: CollectionEntry<"docs">[];
  /** Slug of the page currently being rendered, to mark active. */
  activeSlug: string;
}

const { docs, activeSlug } = Astro.props;

// Group + sort by section, preserving section display order.
const SECTION_ORDER = ["Getting Started", "Features", "Advanced"] as const;

const groups = SECTION_ORDER.map((section) => ({
  section,
  items: docs
    .filter((d) => d.data.section === section)
    .sort((a, b) => a.data.order - b.data.order),
}));

const activeDoc = docs.find((d) => d.id === activeSlug);
const activeTitle = activeDoc?.data.title ?? "Docs";
---

<aside class="docs-sidebar" id="docs-sidebar" data-open="false">
  <!--
    Pagefind CSS + bootstrap. The .js file is generated at build time
    (npm run build runs `pagefind --site dist`) and lives at
    /pagefind/pagefind-ui.js. In `npm run dev` these 404 silently and
    the search renders as a disabled fallback — that's expected.
  -->
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <script src="/pagefind/pagefind-ui.js" is:inline></script>

  <div class="docs-sidebar-bar">
    <!--
      Search trigger: looks like an input but it's a button that opens the
      modal. Real Pagefind UI lives inside the modal further down.
    -->
    <button
      class="docs-search-trigger"
      type="button"
      id="docs-search-trigger"
      aria-label="Search docs"
      aria-haspopup="dialog"
    >
      <svg class="search-icon" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.4" />
        <path d="M9.5 9.5l3 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
      </svg>
      <span class="placeholder">Search docs…</span>
      <kbd class="kbd-hint" aria-hidden="true">
        <span class="kbd-cmd">⌘</span><span class="kbd-ctrl">Ctrl</span>K
      </kbd>
    </button>

    <button
      class="docs-current-page"
      type="button"
      id="docs-current-toggle"
      aria-expanded="false"
    >
      <span class="docs-current-label">{activeTitle}</span>
      <svg class="chev" viewBox="0 0 12 12" fill="none" aria-hidden="true">
        <path
          d="M3 4.5l3 3 3-3"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"
        ></path>
      </svg>
    </button>
  </div>

  <nav class="docs-nav-sections" aria-label="Documentation">
    {
      groups.map((g) => (
        <div class="docs-section">
          <h4>{g.section}</h4>
          {g.items.map((doc) => (
            <a
              href={`/docs/${doc.id}`}
              class="docs-nav-link"
              data-active={doc.id === activeSlug ? "true" : undefined}
            >
              {doc.data.title}
            </a>
          ))}
        </div>
      ))
    }
  </nav>
</aside>

<!--
  Search modal. Lives outside the sidebar so its overlay covers the
  whole viewport. Hidden by default; opened by the trigger button or
  Ctrl/Cmd+K, closed by ESC, backdrop click, or any link selection.
-->
<div
  class="docs-search-modal"
  id="docs-search-modal"
  data-open="false"
  role="dialog"
  aria-modal="true"
  aria-label="Search documentation"
  hidden
>
  <div class="docs-search-backdrop" data-close-modal></div>
  <div class="docs-search-panel" role="document">
    <div class="docs-search-pagefind" id="docs-search"></div>
    <div class="docs-search-footer">
      <span><kbd>↵</kbd> to open</span>
      <span><kbd>esc</kbd> to close</span>
    </div>
  </div>
</div>

<style>
  /* Desktop sidebar */
  .docs-sidebar {
    position: sticky;
    top: 80px;
    height: fit-content;
  }
  /*
   * Search TRIGGER — looks like an input but it's a <button> that opens
   * the modal. The real Pagefind input lives inside the modal.
   */
  .docs-search-trigger {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    padding: 9px 12px;
    margin-bottom: 24px;
    background: var(--color-surface);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-xs);
    color: var(--color-text-tertiary);
    font-family: inherit;
    font-size: 13px;
    cursor: pointer;
    transition: border-color 150ms ease-out;
  }
  .docs-search-trigger:hover {
    border-color: var(--color-border-strong);
  }
  .docs-search-trigger .search-icon {
    width: 14px;
    height: 14px;
    color: var(--color-text-tertiary);
    flex-shrink: 0;
  }
  .docs-search-trigger .placeholder {
    flex: 1;
    text-align: left;
  }
  .docs-search-trigger .kbd-hint {
    display: inline-flex;
    align-items: center;
    gap: 1px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--color-text-tertiary);
    background: var(--color-surface-alt);
    border: 0.5px solid var(--color-border);
    border-radius: 4px;
    padding: 2px 6px;
    line-height: 1;
    flex-shrink: 0;
  }
  /* Show ⌘ on Mac, Ctrl elsewhere */
  .docs-search-trigger .kbd-cmd { display: none; }
  .docs-search-trigger[data-platform="mac"] .kbd-cmd { display: inline; }
  .docs-search-trigger[data-platform="mac"] .kbd-ctrl { display: none; }

  /* Hide the mobile-only "current page" trigger on desktop */
  .docs-sidebar-bar {
    display: contents;
  }
  .docs-current-page {
    display: none;
  }

  /* Section + nav link styles (desktop) */
  .docs-section {
    margin-bottom: 28px;
  }
  .docs-section h4 {
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 8px;
    padding: 0 12px;
  }
  .docs-nav-link {
    display: block;
    padding: 7px 12px;
    font-size: 13px;
    color: var(--color-text-secondary);
    border-radius: 6px;
    font-weight: 500;
  }
  .docs-nav-link:hover {
    background: var(--color-surface-alt);
    color: var(--color-text);
  }
  .docs-nav-link[data-active="true"] {
    background: var(--color-surface);
    color: var(--color-text);
    box-shadow: var(--shadow-xs);
  }

  /* MOBILE — sticky bar with collapsible popover */
  @media (max-width: 900px) {
    .docs-sidebar {
      position: sticky;
      top: 80px;
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(20px) saturate(180%);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      border: 0.5px solid var(--color-border);
      border-radius: 12px;
      padding: 10px;
      margin-bottom: 24px;
      box-shadow:
        0 0 0 0.5px rgba(0, 0, 0, 0.04),
        0 6px 18px rgba(0, 0, 0, 0.06);
      z-index: 50;
    }
    .docs-sidebar-bar {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .docs-search {
      width: 100%;
      margin-bottom: 0;
    }
    .docs-current-page {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 6px;
      width: 100%;
      padding: 9px 12px;
      background: var(--color-surface);
      border: 0.5px solid var(--color-border-strong);
      border-radius: 8px;
      font-family: inherit;
      font-size: 13px;
      font-weight: 500;
      color: var(--color-text);
      cursor: pointer;
      transition: background 150ms ease-out;
    }
    .docs-current-page:hover {
      background: var(--color-surface-alt);
    }
    .docs-current-label {
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      flex: 1;
      text-align: left;
    }
    .docs-current-page .chev {
      width: 11px;
      height: 11px;
      color: var(--color-text-tertiary);
      flex-shrink: 0;
      transition: transform 200ms ease-out;
    }
    .docs-sidebar[data-open="true"] .docs-current-page .chev {
      transform: rotate(180deg);
    }

    /* Sections become a popover that overlays, not pushes */
    .docs-nav-sections {
      position: absolute;
      top: calc(100% + 8px);
      left: 0;
      right: 0;
      background: rgba(255, 255, 255, 0.96);
      backdrop-filter: blur(20px) saturate(180%);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      border: 0.5px solid var(--color-border);
      border-radius: 12px;
      padding: 14px;
      box-shadow:
        0 0 0 0.5px rgba(0, 0, 0, 0.04),
        0 12px 32px rgba(0, 0, 0, 0.12),
        0 4px 10px rgba(0, 0, 0, 0.06);
      max-height: 65vh;
      overflow-y: auto;
      opacity: 0;
      pointer-events: none;
      transform: translateY(-4px);
      transition:
        opacity 200ms ease-out,
        transform 220ms cubic-bezier(0.16, 1, 0.3, 1);
      z-index: 60;
    }
    .docs-sidebar[data-open="true"] .docs-nav-sections {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
    }

    .docs-section {
      margin-bottom: 18px;
    }
    .docs-section h4 {
      padding: 0 8px;
    }
    .docs-nav-link {
      padding: 8px 10px;
    }
  }
  @media (max-width: 700px) {
    .docs-sidebar { top: 60px; }
  }
  @media (max-width: 480px) {
    .docs-sidebar { top: 60px; }
  }

  /* ============================================================
   * SEARCH MODAL — appears centered with a blurred backdrop
   * ============================================================ */
  .docs-search-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 12vh 16px 16px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 180ms ease-out;
  }
  .docs-search-modal[data-open="true"] {
    opacity: 1;
    pointer-events: auto;
  }
  .docs-search-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(20, 20, 22, 0.45);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .docs-search-panel {
    position: relative;
    width: 100%;
    max-width: 640px;
    background: var(--color-surface);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow:
      0 0 0 0.5px rgba(0, 0, 0, 0.04),
      0 20px 60px rgba(0, 0, 0, 0.25),
      0 8px 24px rgba(0, 0, 0, 0.12);
    transform: translateY(-8px) scale(0.98);
    transition: transform 220ms cubic-bezier(0.16, 1, 0.3, 1);
    overflow: hidden;
  }
  .docs-search-modal[data-open="true"] .docs-search-panel {
    transform: translateY(0) scale(1);
  }
  .docs-search-pagefind {
    padding: 14px 16px 4px;
  }
  .docs-search-footer {
    display: flex;
    gap: 16px;
    padding: 10px 16px;
    border-top: 0.5px solid var(--color-border);
    background: var(--color-bg-elevated);
    font-size: 11px;
    color: var(--color-text-tertiary);
  }
  .docs-search-footer kbd {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 18px;
    height: 18px;
    padding: 0 4px;
    margin-right: 6px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--color-text-secondary);
    background: var(--color-surface);
    border: 0.5px solid var(--color-border);
    border-radius: 4px;
    box-shadow: inset 0 -1px 0 rgba(0, 0, 0, 0.04);
  }

  /* ============================================================
   * PAGEFIND UI overrides — match Ditto's design tokens
   * The .pagefind-ui_* class names are public API from Pagefind v1.
   * ============================================================ */
  .docs-search-pagefind :global(.pagefind-ui) {
    --pagefind-ui-scale: 0.8;
    --pagefind-ui-primary: var(--color-text);
    --pagefind-ui-text: var(--color-text);
    --pagefind-ui-background: var(--color-surface);
    --pagefind-ui-border: var(--color-border);
    --pagefind-ui-tag: var(--color-surface-alt);
    --pagefind-ui-border-width: 0.5px;
    --pagefind-ui-border-radius: var(--radius-sm);
    --pagefind-ui-font: var(--font-sans);
  }
  .docs-search-pagefind :global(.pagefind-ui__search-input) {
    font-family: var(--font-sans);
    font-size: 13px;
    box-shadow: var(--shadow-xs);
  }
  /* Hide the clear (×) button that Pagefind injects */
  .docs-search-pagefind :global(.pagefind-ui__search-clear) {
    display: none;
  }
  /* Drop the results UI a little tighter */
  .docs-search-pagefind :global(.pagefind-ui__results) {
    margin-top: 12px;
  }
  .docs-search-pagefind :global(.pagefind-ui__result) {
    border-bottom: 0.5px solid var(--color-border);
    padding: 10px 0;
  }
  .docs-search-pagefind :global(.pagefind-ui__result:last-child) {
    border-bottom: none;
  }
  .docs-search-pagefind :global(.pagefind-ui__result-title a) {
    font-size: 13.5px;
    font-weight: 500;
    color: var(--color-text);
  }
  .docs-search-pagefind :global(.pagefind-ui__result-excerpt) {
    font-size: 12.5px;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }
  .docs-search-pagefind :global(.pagefind-ui__result-excerpt mark) {
    background: rgba(255, 149, 0, 0.18);
    color: var(--color-text);
    padding: 0 2px;
    border-radius: 2px;
  }
</style>

<script>
  /**
   * Mobile-only: toggle the sidebar's data-open state when the current
   * page button is clicked. Click outside closes it. Clicking a nav
   * link follows the link (and the page reload handles state).
   */
  const sidebar = document.getElementById("docs-sidebar");
  const toggle = document.getElementById("docs-current-toggle");

  if (sidebar && toggle) {
    toggle.addEventListener("click", (e) => {
      e.stopPropagation();
      const open = sidebar.dataset.open === "true";
      sidebar.dataset.open = open ? "false" : "true";
      toggle.setAttribute("aria-expanded", String(!open));
    });

    document.addEventListener("click", (e) => {
      if (sidebar.dataset.open === "true" && !sidebar.contains(e.target as Node)) {
        sidebar.dataset.open = "false";
        toggle.setAttribute("aria-expanded", "false");
      }
    });
  }

  /**
   * Search modal: open/close behaviour.
   *  - Click the trigger or press Ctrl/Cmd+K to open.
   *  - Press Esc, click backdrop, or click a result to close.
   *  - Locks <body> scroll while open.
   * The Pagefind UI is initialized lazily on first open (deferred so the
   * pagefind-ui.js script has time to load before we instantiate it).
   */
  const trigger = document.getElementById("docs-search-trigger");
  const modal = document.getElementById("docs-search-modal");
  let pagefindInitialised = false;

  function isMac() {
    return /Mac|iPhone|iPad/.test(navigator.platform);
  }

  if (trigger) {
    if (isMac()) trigger.dataset.platform = "mac";
  }

  function ensurePagefind() {
    if (pagefindInitialised) return;
    const PagefindUI = (window as any).PagefindUI;
    if (typeof PagefindUI !== "function") {
      // In dev mode /pagefind/pagefind-ui.js 404s. Skip silently — search
      // becomes available in production builds.
      return;
    }
    new PagefindUI({
      element: "#docs-search",
      showSubResults: false,
      showImages: false,
      resetStyles: false,
      placeholder: "Search docs…",
    });
    pagefindInitialised = true;
  }

  function openModal() {
    if (!modal) return;
    modal.hidden = false;
    requestAnimationFrame(() => {
      modal.dataset.open = "true";
    });
    document.body.style.overflow = "hidden";
    ensurePagefind();
    // Focus the Pagefind input on next tick so it exists in the DOM.
    setTimeout(() => {
      const input = modal.querySelector<HTMLInputElement>(".pagefind-ui__search-input");
      input?.focus();
    }, 60);
  }

  function closeModal() {
    if (!modal) return;
    modal.dataset.open = "false";
    document.body.style.overflow = "";
    // Wait for the transition to finish before re-hiding from a11y tree.
    setTimeout(() => {
      if (modal.dataset.open === "false") modal.hidden = true;
    }, 200);
  }

  trigger?.addEventListener("click", openModal);

  modal?.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    if (target.dataset.closeModal !== undefined) {
      closeModal();
      return;
    }
    // Closing on result selection: pagefind links inside the modal navigate
    // away by themselves, but make sure we hide the overlay before nav.
    if (target.closest(".pagefind-ui__result-link, .pagefind-ui__result-title a")) {
      closeModal();
    }
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && modal?.dataset.open === "true") {
      e.preventDefault();
      closeModal();
      return;
    }
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
      e.preventDefault();
      if (modal?.dataset.open === "true") {
        closeModal();
      } else {
        openModal();
      }
    }
  });
</script>
