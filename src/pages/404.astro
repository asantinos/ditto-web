---
/**
 * Custom 404. Astro auto-serves this file on any unknown route.
 *
 * Keeps the brand: a big aurora pill at the top, plain "Page not
 * found" headline, two actions (back to home + browse docs). Tone
 * is friendly, not snarky.
 */
import Layout from "../layouts/Layout.astro";
import Pill from "../components/ui/Pill.astro";
import GhostLink from "../components/ui/GhostLink.astro";
---

<Layout
  title="Page not found — Ditto"
  description="The page you're looking for doesn't exist. Head back to the home page or browse the docs."
>
  <main class="not-found">
    <div class="pill-stage">
      <Pill theme="aurora" state="idle" id="not-found" />
    </div>

    <div class="badge">404</div>
    <h1>This page got <span class="display-italic">lost</span>.</h1>
    <p>
      The URL you followed doesn't lead anywhere on Ditto. It may have moved,
      or it never existed in the first place.
    </p>

    <div class="actions">
      <a class="btn-home" href="/">Back to home</a>
      <GhostLink href="/docs">Browse the docs</GhostLink>
    </div>
  </main>
</Layout>

<style>
  .not-found {
    max-width: 640px;
    margin: 0 auto;
    padding: 80px 32px 120px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .pill-stage {
    display: inline-flex;
    transform: scale(1.5);
    transform-origin: center;
    margin-bottom: 56px;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 5px 12px;
    background: var(--color-surface);
    border: 0.5px solid var(--color-border);
    border-radius: 100px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text-secondary);
    letter-spacing: 0.12em;
    box-shadow: var(--shadow-xs);
    margin-bottom: 20px;
  }

  h1 {
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin-bottom: 16px;
  }

  p {
    font-size: 16px;
    line-height: 1.55;
    color: var(--color-text-secondary);
    max-width: 460px;
    margin: 0 auto 36px;
  }

  .actions {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn-home {
    display: inline-flex;
    align-items: center;
    padding: 12px 22px;
    background: var(--color-accent);
    color: #fff;
    border: 0.5px solid transparent;
    border-radius: var(--radius-md);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.01em;
    box-shadow: var(--shadow-xs);
    transition:
      background 150ms ease-out,
      transform 200ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .btn-home:hover {
    background: var(--color-accent-hover);
    transform: translateY(-1px);
  }

  /* Responsive */
  @media (max-width: 700px) {
    .not-found {
      padding: 56px 24px 80px;
    }
    .pill-stage {
      transform: scale(1.2);
      margin-bottom: 40px;
    }
    .actions {
      flex-direction: column;
      width: 100%;
    }
    .btn-home,
    .actions :global(.btn-ghost-link) {
      width: 100%;
      justify-content: center;
    }
  }
  @media (max-width: 480px) {
    .not-found {
      padding: 40px 20px 64px;
    }
    .pill-stage {
      transform: scale(1.05);
    }
  }
</style>
