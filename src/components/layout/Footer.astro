---
/**
 * Site footer. 4-column grid (brand + 3 link cols) collapsing to
 * 2 cols at ≤900px and 1 col at ≤700px.
 *
 * Bottom strip shows copyright + current release version (filled
 * dynamically by the GitHub fetch in Layout.astro).
 */
import Logo from "../ui/Logo.astro";

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <Logo as="div" />
      <p class="footer-tagline">
        Voice to text, everywhere you type. Local, private, fast.
      </p>
    </div>

    <div class="footer-col">
      <h4>Product</h4>
      <a href="/">Home</a>
      <a href="/download">Download</a>
      <a href="/changelog">Changelog</a>
    </div>

    <div class="footer-col">
      <h4>Resources</h4>
      <a href="/docs">Documentation</a>
      <a href="https://github.com/asantinos/ditto" target="_blank" rel="noopener">GitHub</a>
      <a href="/docs/privacy-and-data">Privacy</a>
    </div>

    <div class="footer-col">
      <h4>Connect</h4>
      <a href="https://x.com/asantinos" target="_blank" rel="noopener">X / Twitter</a>
      <a href="mailto:hello@dittotalks.com">Email</a>
    </div>
  </div>

  <div class="footer-bottom">
    <div>© {year} Ditto. Built with care.</div>
    <div class="js-release-version">v1.0.0</div>
  </div>
</footer>

<style>
  .footer {
    border-top: 0.5px solid var(--color-border);
    background: var(--color-bg-elevated);
    padding: 60px 32px 40px;
  }
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 48px;
    margin-bottom: 56px;
  }
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .footer-tagline {
    font-size: 13px;
    color: var(--color-text-secondary);
    line-height: 1.5;
    max-width: 320px;
  }
  .footer-col h4 {
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 16px;
  }
  .footer-col a {
    display: block;
    font-size: 13px;
    color: var(--color-text-secondary);
    padding: 4px 0;
    transition: color 150ms ease-out;
  }
  .footer-col a:hover { color: var(--color-text); }

  .footer-bottom {
    max-width: 1200px;
    margin: 0 auto;
    padding-top: 24px;
    border-top: 0.5px solid var(--color-border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
    color: var(--color-text-tertiary);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .footer-inner { grid-template-columns: 1fr 1fr; }
    .footer { padding: 60px 24px 0; }
  }
  @media (max-width: 700px) {
    .footer { padding: 48px 24px 0; }
    .footer-inner { grid-template-columns: 1fr; gap: 32px; padding: 0; }
    .footer-bottom {
      flex-direction: column;
      gap: 8px;
      text-align: center;
      padding: 20px 0;
    }
  }
  @media (max-width: 480px) {
    .footer { padding: 40px 20px 0; }
  }
</style>
