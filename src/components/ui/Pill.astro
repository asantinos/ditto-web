---
/**
 * Pill — the canonical Ditto pill (CLAUDE.md §5.1).
 *
 * The pill is the floating window the desktop app shows during recording.
 * It's also reused as a visual anchor across the website (hero, themes
 * showcase, download CTA, etc.).
 *
 * Tokens calibrated in the original HTML mockup, ported verbatim. Don't
 * invent new values — width/height base stay 100×44 (idle). To resize,
 * wrap in a container with `transform: scale(N)`.
 */

export type PillTheme = "matte" | "onyx" | "aurora" | "sunset" | "mint";
export type PillState = "idle" | "recording" | "transcribing" | "copied";

interface Props {
  theme?: PillTheme;
  state?: PillState;
  /**
   * Removes outer shadows so the pill can sit inline (e.g. embedded in the
   * hero title). Use sparingly — only when the pill needs to feel "flat"
   * against text, never standalone.
   */
  flat?: boolean;
  /**
   * Stable id used by the wave gradient SVG. Required because each pill
   * needs its own gradient `<defs>` to avoid id collisions when multiple
   * pills render on the same page.
   */
  id?: string;
  class?: string;
}

const {
  theme = "matte",
  state = "idle",
  flat = false,
  id,
  class: className = "",
} = Astro.props;

// Stable per-render id for the gradient (Astro generates a unique scope hash
// per component instance, so this is safe across multiple pills).
const gradId = id ? `wave-grad-${id}` : `wave-grad-${Math.random().toString(36).slice(2, 9)}`;
---

<div
  class:list={["pill", { "pill-flat": flat }, className]}
  data-theme={theme}
  data-state={state}
>
  <!-- Aurora blobs (visible only on aurora/sunset/mint, see CSS rule) -->
  <div class="aurora-wrap">
    <div class="aurora-blob b1"></div>
    <div class="aurora-blob b2"></div>
    <div class="aurora-blob b3"></div>
    <div class="aurora-blob b4"></div>
  </div>

  <!-- Bottom wave (visible on aurora/sunset/mint while recording) -->
  <svg class="wave-bottom" viewBox="0 0 160 32" preserveAspectRatio="none">
    <defs>
      <linearGradient id={gradId} x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="var(--wave-color, #5ec2d6)" stop-opacity="0" />
        <stop offset="60%" stop-color="var(--wave-color, #5ec2d6)" stop-opacity="0.55" />
        <stop offset="100%" stop-color="var(--wave-color, #5ec2d6)" stop-opacity="0.95" />
      </linearGradient>
    </defs>
    <path class="wave-path" d="M 0 32 L 160 32 Z" fill={`url(#${gradId})`} />
  </svg>

  <div class="content">
    <span class="ditto-text">Ditto</span>
    <div class="waveform">
      {Array.from({ length: 13 }).map(() => <span class="wb"></span>)}
    </div>
    <div class="dots-loader">
      {Array.from({ length: 8 }).map(() => <span></span>)}
    </div>
  </div>
</div>

<style>
  /* ============================================================
   * BASE
   * ============================================================ */
  .pill {
    height: 44px;
    width: 100px;
    border-radius: 22px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 0 16px;
    user-select: none;
    background: var(--pill-bg);
    box-shadow: var(--pill-shadow);
    transition:
      width 500ms cubic-bezier(0.32, 0.72, 0.24, 1),
      border-radius 500ms cubic-bezier(0.32, 0.72, 0.24, 1),
      background 600ms ease-out,
      box-shadow 600ms ease-out;
  }
  .pill::before {
    content: "";
    position: absolute;
    top: 1px;
    left: 20%;
    right: 20%;
    height: 1px;
    background: var(--pill-highlight-top);
    border-radius: 50%;
    pointer-events: none;
    z-index: 10;
  }
  .pill::after {
    content: "";
    position: absolute;
    bottom: 2px;
    left: 30%;
    right: 30%;
    height: 1px;
    background: var(--pill-highlight-bottom);
    border-radius: 50%;
    pointer-events: none;
    z-index: 10;
  }

  /* States */
  .pill[data-state="idle"] { width: 100px; }
  .pill[data-state="recording"] { width: 160px; }
  .pill[data-state="transcribing"] { width: 44px; border-radius: 50%; }

  /* Flat variant — kills outer shadows, used inline in titles */
  .pill.pill-flat {
    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, 1),
      inset 0 2px 4px rgba(255, 255, 255, 0.6),
      inset 0 -1px 1px rgba(0, 0, 0, 0.04),
      inset 0 -8px 16px rgba(0, 0, 0, 0.05),
      0 0 0 0.5px rgba(0, 0, 0, 0.08);
  }

  /* ============================================================
   * AURORA BLOBS (aurora/sunset/mint themes)
   * ============================================================ */
  .aurora-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
    border-radius: inherit;
    z-index: 1;
    display: none;
  }
  .pill[data-theme="aurora"] .aurora-wrap,
  .pill[data-theme="sunset"] .aurora-wrap,
  .pill[data-theme="mint"] .aurora-wrap {
    display: block;
  }
  .aurora-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(18px);
    mix-blend-mode: multiply;
    opacity: 0.3;
    transition:
      opacity 600ms ease-out,
      filter 600ms ease-out,
      width 500ms cubic-bezier(0.32, 0.72, 0.24, 1),
      height 500ms cubic-bezier(0.32, 0.72, 0.24, 1);
  }
  .aurora-blob.b1 {
    width: 96px; height: 96px;
    background: radial-gradient(circle, var(--blob-1) 0%, transparent 70%);
    animation: idleDrift1 9s ease-in-out infinite;
  }
  .aurora-blob.b2 {
    width: 88px; height: 88px;
    background: radial-gradient(circle, var(--blob-2) 0%, transparent 70%);
    animation: idleDrift2 11s ease-in-out infinite;
  }
  .aurora-blob.b3 {
    width: 84px; height: 84px;
    background: radial-gradient(circle, var(--blob-3) 0%, transparent 70%);
    animation: idleDrift3 8s ease-in-out infinite;
  }
  .aurora-blob.b4 {
    width: 80px; height: 80px;
    background: radial-gradient(circle, var(--blob-4) 0%, transparent 70%);
    animation: idleDrift4 10s ease-in-out infinite;
  }
  @keyframes idleDrift1 { 0%, 100% { transform: translate(-30px, -4px) scale(1); } 50% { transform: translate(7px, 6px) scale(1.05); } }
  @keyframes idleDrift2 { 0%, 100% { transform: translate(15px, 7px) scale(1); }   50% { transform: translate(-11px, -6px) scale(1.05); } }
  @keyframes idleDrift3 { 0%, 100% { transform: translate(0, 6px) scale(0.95); }   50% { transform: translate(11px, -7px) scale(1.05); } }
  @keyframes idleDrift4 { 0%, 100% { transform: translate(-11px, 0) scale(0.95); } 50% { transform: translate(15px, 4px) scale(1.05); } }

  /* While recording on coloured themes, blobs hide (wave takes over) */
  .pill[data-theme="aurora"][data-state="recording"] .aurora-blob,
  .pill[data-theme="sunset"][data-state="recording"] .aurora-blob,
  .pill[data-theme="mint"][data-state="recording"] .aurora-blob {
    display: none;
  }

  /* While transcribing, blobs become an orbit loader */
  .pill[data-state="transcribing"] .aurora-blob {
    opacity: 0.85;
    filter: blur(10px) saturate(1.6);
    width: 36px; height: 36px;
    top: 50%; left: 50%;
    margin-top: -18px; margin-left: -18px;
    transform-origin: center center;
  }
  .pill[data-state="transcribing"] .aurora-blob.b1 { animation: orbit1 2.5s linear infinite; }
  .pill[data-state="transcribing"] .aurora-blob.b2 { animation: orbit2 3s   linear infinite; }
  .pill[data-state="transcribing"] .aurora-blob.b3 { animation: orbit3 2.2s linear infinite; }
  .pill[data-state="transcribing"] .aurora-blob.b4 { animation: orbit4 2.7s linear infinite; }
  @keyframes orbit1 { 0% { transform: rotate(0deg)   translateX(13px) rotate(0deg);   } 100% { transform: rotate(360deg) translateX(13px) rotate(-360deg); } }
  @keyframes orbit2 { 0% { transform: rotate(90deg)  translateX(11px) rotate(-90deg); } 100% { transform: rotate(450deg) translateX(11px) rotate(-450deg); } }
  @keyframes orbit3 { 0% { transform: rotate(180deg) translateX(15px) rotate(-180deg); } 100% { transform: rotate(540deg) translateX(15px) rotate(-540deg); } }
  @keyframes orbit4 { 0% { transform: rotate(270deg) translateX(12px) rotate(-270deg); } 100% { transform: rotate(630deg) translateX(12px) rotate(-630deg); } }

  /* ============================================================
   * WAVE BOTTOM (aurora/sunset/mint, recording state only)
   * ============================================================ */
  .wave-bottom {
    position: absolute;
    bottom: 0; left: 0;
    width: 100%; height: 32px;
    z-index: 2;
    pointer-events: none;
    display: none;
    border-radius: 0 0 22px 22px;
    overflow: hidden;
  }
  .pill[data-theme="aurora"][data-state="recording"] .wave-bottom,
  .pill[data-theme="sunset"][data-state="recording"] .wave-bottom,
  .pill[data-theme="mint"][data-state="recording"] .wave-bottom {
    display: block;
  }

  /* ============================================================
   * CONTENT — Ditto text, waveform bars, dots loader
   * ============================================================ */
  .pill .content {
    position: relative;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }
  .ditto-text {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--emboss-color);
    text-shadow:
      0 1px 0 var(--emboss-highlight),
      0 -1px 1px var(--emboss-shadow);
    filter: contrast(1.05);
    white-space: nowrap;
    display: none;
  }
  .pill[data-state="idle"] .ditto-text { display: inline-block; }

  .waveform {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 3px;
    height: 23px;
  }
  .pill[data-theme="matte"][data-state="recording"] .waveform,
  .pill[data-theme="onyx"][data-state="recording"] .waveform {
    display: flex;
  }
  .wb {
    width: 3px;
    height: 19px;
    background: var(--bar-color);
    border-radius: 2px;
    transform-origin: center;
    transform: scaleY(0.15);
    opacity: 1;
    transition: transform 80ms linear;
  }
  /* Levels are set via --lvl-N CSS vars by the JS animator */
  .pill[data-state="recording"] .wb:nth-child(1)  { transform: scaleY(calc(0.15 + var(--lvl-0,  0) * 0.85)); }
  .pill[data-state="recording"] .wb:nth-child(2)  { transform: scaleY(calc(0.15 + var(--lvl-1,  0) * 0.85)); }
  .pill[data-state="recording"] .wb:nth-child(3)  { transform: scaleY(calc(0.15 + var(--lvl-2,  0) * 0.85)); }
  .pill[data-state="recording"] .wb:nth-child(4)  { transform: scaleY(calc(0.15 + var(--lvl-3,  0) * 0.85)); }
  .pill[data-state="recording"] .wb:nth-child(5)  { transform: scaleY(calc(0.15 + var(--lvl-4,  0) * 0.85)); }
  .pill[data-state="recording"] .wb:nth-child(6)  { transform: scaleY(calc(0.15 + var(--lvl-5,  0) * 0.85)); }
  .pill[data-state="recording"] .wb:nth-child(7)  { transform: scaleY(calc(0.15 + var(--lvl-6,  0) * 0.85)); }
  .pill[data-state="recording"] .wb:nth-child(8)  { transform: scaleY(calc(0.15 + var(--lvl-7,  0) * 0.85)); }
  .pill[data-state="recording"] .wb:nth-child(9)  { transform: scaleY(calc(0.15 + var(--lvl-8,  0) * 0.85)); }
  .pill[data-state="recording"] .wb:nth-child(10) { transform: scaleY(calc(0.15 + var(--lvl-9,  0) * 0.85)); }
  .pill[data-state="recording"] .wb:nth-child(11) { transform: scaleY(calc(0.15 + var(--lvl-10, 0) * 0.85)); }
  .pill[data-state="recording"] .wb:nth-child(12) { transform: scaleY(calc(0.15 + var(--lvl-11, 0) * 0.85)); }
  .pill[data-state="recording"] .wb:nth-child(13) { transform: scaleY(calc(0.15 + var(--lvl-12, 0) * 0.85)); }

  .dots-loader {
    display: none;
    position: relative;
    width: 26px;
    height: 26px;
  }
  .pill[data-theme="matte"][data-state="transcribing"] .dots-loader,
  .pill[data-theme="onyx"][data-state="transcribing"] .dots-loader {
    display: block;
    animation: rotateLoader 1.2s linear infinite;
  }
  .dots-loader span {
    position: absolute;
    width: 4px; height: 4px;
    border-radius: 50%;
    background: var(--bar-color);
    top: 50%; left: 50%;
    margin: -2px 0 0 -2px;
    animation: dotPulseLoader 1.2s ease-in-out infinite;
  }
  .dots-loader span:nth-child(1) { transform: rotate(0deg)   translateX(10px); animation-delay: -1.05s; }
  .dots-loader span:nth-child(2) { transform: rotate(45deg)  translateX(10px); animation-delay: -0.9s;  }
  .dots-loader span:nth-child(3) { transform: rotate(90deg)  translateX(10px); animation-delay: -0.75s; }
  .dots-loader span:nth-child(4) { transform: rotate(135deg) translateX(10px); animation-delay: -0.6s;  }
  .dots-loader span:nth-child(5) { transform: rotate(180deg) translateX(10px); animation-delay: -0.45s; }
  .dots-loader span:nth-child(6) { transform: rotate(225deg) translateX(10px); animation-delay: -0.3s;  }
  .dots-loader span:nth-child(7) { transform: rotate(270deg) translateX(10px); animation-delay: -0.15s; }
  .dots-loader span:nth-child(8) { transform: rotate(315deg) translateX(10px); animation-delay: 0s;     }
  @keyframes rotateLoader { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  @keyframes dotPulseLoader { 0%, 100% { opacity: 0.2; } 50% { opacity: 1; } }

  /* ============================================================
   * THEMES — set via [data-theme] on the .pill (NOT global)
   * ============================================================ */
  .pill[data-theme="matte"] {
    --pill-bg: linear-gradient(180deg, #ffffff 0%, #fafafb 30%, #efeff1 70%, #e8e8ea 100%);
    --pill-shadow:
      0 1px 2px rgba(0, 0, 0, 0.08),
      0 8px 16px rgba(0, 0, 0, 0.12),
      0 24px 48px rgba(0, 0, 0, 0.22),
      inset 0 1px 1px rgba(255, 255, 255, 1),
      inset 0 2px 4px rgba(255, 255, 255, 0.6),
      inset 0 -1px 1px rgba(0, 0, 0, 0.04),
      inset 0 -8px 16px rgba(0, 0, 0, 0.05);
    --pill-highlight-top: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.95) 50%, transparent 100%);
    --pill-highlight-bottom: linear-gradient(90deg, transparent 0%, rgba(0, 0, 0, 0.06) 50%, transparent 100%);
    --emboss-color: #c8c8cc;
    --emboss-highlight: rgba(255, 255, 255, 0.9);
    --emboss-shadow: rgba(0, 0, 0, 0.18);
    --bar-color: #1d1d1f;
  }
  .pill[data-theme="onyx"] {
    --pill-bg: linear-gradient(180deg, #2c2c2e 0%, #232326 30%, #1a1a1d 70%, #131316 100%);
    --pill-shadow:
      0 1px 2px rgba(0, 0, 0, 0.4),
      0 8px 16px rgba(0, 0, 0, 0.35),
      0 24px 48px rgba(0, 0, 0, 0.45),
      inset 0 1px 1px rgba(255, 255, 255, 0.12),
      inset 0 2px 4px rgba(255, 255, 255, 0.06),
      inset 0 -1px 1px rgba(0, 0, 0, 0.5),
      inset 0 -8px 16px rgba(0, 0, 0, 0.3);
    --pill-highlight-top: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.18) 50%, transparent 100%);
    --pill-highlight-bottom: linear-gradient(90deg, transparent 0%, rgba(0, 0, 0, 0.4) 50%, transparent 100%);
    --emboss-color: #4a4a4d;
    --emboss-highlight: rgba(255, 255, 255, 0.08);
    --emboss-shadow: rgba(0, 0, 0, 0.6);
    --bar-color: #f0f0f2;
  }
  .pill[data-theme="aurora"] {
    --pill-bg: linear-gradient(180deg, #ffffff 0%, #fafafb 30%, #efeff1 70%, #e8e8ea 100%);
    --pill-shadow:
      0 1px 2px rgba(0, 0, 0, 0.08),
      0 8px 16px rgba(0, 0, 0, 0.12),
      0 24px 48px rgba(0, 0, 0, 0.22),
      inset 0 1px 1px rgba(255, 255, 255, 1),
      inset 0 2px 4px rgba(255, 255, 255, 0.6),
      inset 0 -1px 1px rgba(0, 0, 0, 0.04),
      inset 0 -8px 16px rgba(0, 0, 0, 0.05);
    --pill-highlight-top: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.95) 50%, transparent 100%);
    --pill-highlight-bottom: linear-gradient(90deg, transparent 0%, rgba(0, 0, 0, 0.06) 50%, transparent 100%);
    --emboss-color: #c8c8cc;
    --emboss-highlight: rgba(255, 255, 255, 0.9);
    --emboss-shadow: rgba(0, 0, 0, 0.18);
    --blob-1: #ff8fb1;
    --blob-2: #7aa5f2;
    --blob-3: #c49aff;
    --blob-4: #ffb67a;
    --bar-color: rgba(29, 29, 31, 0.85);
    --wave-color: #c49aff;
  }
  .pill[data-theme="sunset"] {
    --pill-bg: linear-gradient(180deg, #fffaf6 0%, #fff4ed 30%, #fceae0 70%, #f8e0d2 100%);
    --pill-shadow:
      0 1px 2px rgba(180, 80, 40, 0.1),
      0 8px 16px rgba(180, 80, 40, 0.12),
      0 24px 48px rgba(180, 80, 40, 0.22),
      inset 0 1px 1px rgba(255, 255, 255, 1),
      inset 0 2px 4px rgba(255, 255, 255, 0.6),
      inset 0 -1px 1px rgba(180, 80, 40, 0.06),
      inset 0 -8px 16px rgba(180, 80, 40, 0.05);
    --pill-highlight-top: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.95) 50%, transparent 100%);
    --pill-highlight-bottom: linear-gradient(90deg, transparent 0%, rgba(120, 40, 20, 0.08) 50%, transparent 100%);
    --emboss-color: #e8c8b5;
    --emboss-highlight: rgba(255, 255, 255, 0.9);
    --emboss-shadow: rgba(120, 40, 20, 0.18);
    --blob-1: #ff8fb1;
    --blob-2: #ffb67a;
    --blob-3: #ff6b6b;
    --blob-4: #ffd27a;
    --bar-color: rgba(80, 30, 20, 0.85);
    --wave-color: #ff7a4d;
  }
  .pill[data-theme="mint"] {
    --pill-bg: linear-gradient(180deg, #f6fffc 0%, #edf9f4 30%, #e0f2ea 70%, #d2e9dd 100%);
    --pill-shadow:
      0 1px 2px rgba(20, 100, 80, 0.1),
      0 8px 16px rgba(20, 100, 80, 0.12),
      0 24px 48px rgba(20, 100, 80, 0.22),
      inset 0 1px 1px rgba(255, 255, 255, 1),
      inset 0 2px 4px rgba(255, 255, 255, 0.6),
      inset 0 -1px 1px rgba(20, 100, 80, 0.06),
      inset 0 -8px 16px rgba(20, 100, 80, 0.05);
    --pill-highlight-top: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.95) 50%, transparent 100%);
    --pill-highlight-bottom: linear-gradient(90deg, transparent 0%, rgba(20, 80, 60, 0.08) 50%, transparent 100%);
    --emboss-color: #b5dcc8;
    --emboss-highlight: rgba(255, 255, 255, 0.9);
    --emboss-shadow: rgba(20, 80, 60, 0.18);
    --blob-1: #7ae3c3;
    --blob-2: #5ec2d6;
    --blob-3: #9dd9b8;
    --blob-4: #6fcfe0;
    --bar-color: rgba(20, 60, 50, 0.85);
    --wave-color: #5ec2d6;
  }
</style>

<script>
  /**
   * Animates the pill's voice-reactive visualization.
   *
   * For matte/onyx (waveform bars): writes 13 CSS variables (--lvl-0..--lvl-12)
   * with synthetic pseudo-noise levels. CSS uses them in calc() to scale bars.
   *
   * For aurora/sunset/mint (wave path): rebuilds the SVG path with bezier
   * curves through the 13 level points, producing a smooth wave that
   * animates with the same data.
   *
   * One animation loop per pill on the page. The loop always runs; CSS
   * decides whether bars or wave are visible based on theme + state.
   */
  type LiveSVGPathElement = SVGPathElement;

  function animatePill(pillEl: HTMLElement) {
    const path = pillEl.querySelector<LiveSVGPathElement>(".wave-path");
    const W = 160;
    const H = 32;
    const N = 13;

    function tick(t: number) {
      const tt = t / 1000;
      const state = pillEl.dataset.state;
      const active = state === "recording";
      const levels = new Array<number>(N);

      for (let i = 0; i < N; i++) {
        const v = active
          ? 0.3 + 0.35 * Math.sin(tt * 3 + i * 0.7) + 0.2 * Math.sin(tt * 7 + i * 1.3)
          : 0;
        const clamped = Math.max(0, Math.min(1, v));
        levels[i] = clamped;
        pillEl.style.setProperty(`--lvl-${i}`, clamped.toFixed(3));
      }

      if (path) {
        const pts: [number, number][] = levels.map((l, i) => [(i / (N - 1)) * W, H - l * (H - 2)]);
        let d = `M 0 ${H} L ${pts[0][0].toFixed(2)} ${pts[0][1].toFixed(2)} `;
        for (let i = 1; i < N; i++) {
          const [px, py] = pts[i - 1];
          const [cx, cy] = pts[i];
          const dx = (cx - px) / 2;
          d += `C ${(px + dx).toFixed(2)} ${py.toFixed(2)}, ${(cx - dx).toFixed(2)} ${cy.toFixed(2)}, ${cx.toFixed(2)} ${cy.toFixed(2)} `;
        }
        d += `L ${W} ${H} Z`;
        path.setAttribute("d", d);
      }

      requestAnimationFrame(tick);
    }

    requestAnimationFrame(tick);
  }

  document.querySelectorAll<HTMLElement>(".pill").forEach(animatePill);
</script>
