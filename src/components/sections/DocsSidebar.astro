---
/**
 * Docs sidebar — search + grouped nav list.
 *
 * Desktop: 240px column on the left of the docs layout, sticky.
 * Mobile (≤900): collapses to a sticky bar at top with the search and
 * the current page name + chevron. Tapping the trigger expands a popover
 * with all sections (overlays content; doesn't push it).
 */
import type { CollectionEntry } from "astro:content";

interface Props {
  /** All docs in the collection, used to build the grouped nav. */
  docs: CollectionEntry<"docs">[];
  /** Slug of the page currently being rendered, to mark active. */
  activeSlug: string;
}

const { docs, activeSlug } = Astro.props;

// Group + sort by section, preserving section display order.
const SECTION_ORDER = ["Getting Started", "Features", "Advanced"] as const;

const groups = SECTION_ORDER.map((section) => ({
  section,
  items: docs
    .filter((d) => d.data.section === section)
    .sort((a, b) => a.data.order - b.data.order),
}));

const activeDoc = docs.find((d) => d.id === activeSlug);
const activeTitle = activeDoc?.data.title ?? "Docs";
---

<aside class="docs-sidebar" id="docs-sidebar" data-open="false">
  <div class="docs-sidebar-bar">
    <input
      type="search"
      class="docs-search"
      placeholder="Search docs…"
      aria-label="Search docs"
    />
    <button
      class="docs-current-page"
      type="button"
      id="docs-current-toggle"
      aria-expanded="false"
    >
      <span class="docs-current-label">{activeTitle}</span>
      <svg class="chev" viewBox="0 0 12 12" fill="none" aria-hidden="true">
        <path
          d="M3 4.5l3 3 3-3"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"
        ></path>
      </svg>
    </button>
  </div>

  <nav class="docs-nav-sections" aria-label="Documentation">
    {
      groups.map((g) => (
        <div class="docs-section">
          <h4>{g.section}</h4>
          {g.items.map((doc) => (
            <a
              href={`/docs/${doc.id}`}
              class="docs-nav-link"
              data-active={doc.id === activeSlug ? "true" : undefined}
            >
              {doc.data.title}
            </a>
          ))}
        </div>
      ))
    }
  </nav>
</aside>

<style>
  /* Desktop sidebar */
  .docs-sidebar {
    position: sticky;
    top: 80px;
    height: fit-content;
  }
  .docs-search {
    width: 100%;
    padding: 9px 14px 9px 36px;
    font-family: inherit;
    font-size: 13px;
    background: var(--color-surface);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-xs);
    color: var(--color-text);
    margin-bottom: 24px;
    background-image: url("data:image/svg+xml,%3Csvg width='14' height='14' viewBox='0 0 14 14' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='6' cy='6' r='4.5' stroke='%238E8E93' stroke-width='1.4'/%3E%3Cpath d='M9.5 9.5l3 3' stroke='%238E8E93' stroke-width='1.4' stroke-linecap='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: 12px center;
  }
  .docs-search:focus {
    outline: none;
    border-color: var(--color-text);
  }
  .docs-search::-webkit-search-cancel-button,
  .docs-search::-webkit-search-decoration,
  .docs-search::-webkit-search-results-button,
  .docs-search::-webkit-search-results-decoration {
    -webkit-appearance: none;
    appearance: none;
    display: none;
  }
  .docs-search::-ms-clear {
    display: none;
    width: 0;
    height: 0;
  }

  /* Hide the mobile-only "current page" trigger on desktop */
  .docs-sidebar-bar {
    display: contents;
  }
  .docs-current-page {
    display: none;
  }

  /* Section + nav link styles (desktop) */
  .docs-section {
    margin-bottom: 28px;
  }
  .docs-section h4 {
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 8px;
    padding: 0 12px;
  }
  .docs-nav-link {
    display: block;
    padding: 7px 12px;
    font-size: 13px;
    color: var(--color-text-secondary);
    border-radius: 6px;
    font-weight: 500;
  }
  .docs-nav-link:hover {
    background: var(--color-surface-alt);
    color: var(--color-text);
  }
  .docs-nav-link[data-active="true"] {
    background: var(--color-surface);
    color: var(--color-text);
    box-shadow: var(--shadow-xs);
  }

  /* MOBILE — sticky bar with collapsible popover */
  @media (max-width: 900px) {
    .docs-sidebar {
      position: sticky;
      top: 80px;
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(20px) saturate(180%);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      border: 0.5px solid var(--color-border);
      border-radius: 12px;
      padding: 10px;
      margin-bottom: 24px;
      box-shadow:
        0 0 0 0.5px rgba(0, 0, 0, 0.04),
        0 6px 18px rgba(0, 0, 0, 0.06);
      z-index: 50;
    }
    .docs-sidebar-bar {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .docs-search {
      width: 100%;
      padding: 9px 14px 9px 36px;
      font-size: 13px;
      margin-bottom: 0;
    }
    .docs-current-page {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 6px;
      width: 100%;
      padding: 9px 12px;
      background: var(--color-surface);
      border: 0.5px solid var(--color-border-strong);
      border-radius: 8px;
      font-family: inherit;
      font-size: 13px;
      font-weight: 500;
      color: var(--color-text);
      cursor: pointer;
      transition: background 150ms ease-out;
    }
    .docs-current-page:hover {
      background: var(--color-surface-alt);
    }
    .docs-current-label {
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      flex: 1;
      text-align: left;
    }
    .docs-current-page .chev {
      width: 11px;
      height: 11px;
      color: var(--color-text-tertiary);
      flex-shrink: 0;
      transition: transform 200ms ease-out;
    }
    .docs-sidebar[data-open="true"] .docs-current-page .chev {
      transform: rotate(180deg);
    }

    /* Sections become a popover that overlays, not pushes */
    .docs-nav-sections {
      position: absolute;
      top: calc(100% + 8px);
      left: 0;
      right: 0;
      background: rgba(255, 255, 255, 0.96);
      backdrop-filter: blur(20px) saturate(180%);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      border: 0.5px solid var(--color-border);
      border-radius: 12px;
      padding: 14px;
      box-shadow:
        0 0 0 0.5px rgba(0, 0, 0, 0.04),
        0 12px 32px rgba(0, 0, 0, 0.12),
        0 4px 10px rgba(0, 0, 0, 0.06);
      max-height: 65vh;
      overflow-y: auto;
      opacity: 0;
      pointer-events: none;
      transform: translateY(-4px);
      transition:
        opacity 200ms ease-out,
        transform 220ms cubic-bezier(0.16, 1, 0.3, 1);
      z-index: 60;
    }
    .docs-sidebar[data-open="true"] .docs-nav-sections {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
    }

    .docs-section {
      margin-bottom: 18px;
    }
    .docs-section h4 {
      padding: 0 8px;
    }
    .docs-nav-link {
      padding: 8px 10px;
    }
  }
  @media (max-width: 700px) {
    .docs-sidebar { top: 60px; }
  }
  @media (max-width: 480px) {
    .docs-sidebar { top: 60px; }
  }
</style>

<script>
  /**
   * Mobile-only: toggle the sidebar's data-open state when the current
   * page button is clicked. Click outside closes it. Clicking a nav
   * link follows the link (and the page reload handles state).
   */
  const sidebar = document.getElementById("docs-sidebar");
  const toggle = document.getElementById("docs-current-toggle");

  if (sidebar && toggle) {
    toggle.addEventListener("click", (e) => {
      e.stopPropagation();
      const open = sidebar.dataset.open === "true";
      sidebar.dataset.open = open ? "false" : "true";
      toggle.setAttribute("aria-expanded", String(!open));
    });

    document.addEventListener("click", (e) => {
      if (sidebar.dataset.open === "true" && !sidebar.contains(e.target as Node)) {
        sidebar.dataset.open = "false";
        toggle.setAttribute("aria-expanded", "false");
      }
    });
  }
</script>
