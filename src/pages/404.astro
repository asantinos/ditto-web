---
/**
 * Custom 404. Astro auto-serves this file on any unknown route.
 *
 * Composition: 404 mono badge → "lost" headline → friendly paragraph
 * → primary "Back to home" + ghost "Browse docs". Header + Footer
 * come from Layout.
 */
import Layout from "../layouts/Layout.astro";
import GhostLink from "../components/ui/GhostLink.astro";
---

<Layout
  title="Page not found — Ditto"
  description="The page you're looking for doesn't exist. Head back to the home page or browse the docs."
>
  <main class="not-found">
    <div class="badge">404</div>
    <h1>This page got <span class="display-italic">lost</span>.</h1>
    <p>
      The URL you followed doesn't lead anywhere on Ditto. It may have moved,
      or it never existed in the first place.
    </p>

    <div class="actions">
      <a class="btn-primary" href="/">Back to home</a>
      <GhostLink href="/docs">Browse the docs</GhostLink>
    </div>
  </main>
</Layout>

<style>
  .not-found {
    max-width: 640px;
    margin: 0 auto;
    padding: 140px 32px 160px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* 404 badge — same mono-uppercase pattern as .section-tag */
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 6px 14px;
    background: var(--color-surface);
    border: 0.5px solid var(--color-border);
    border-radius: 100px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text-secondary);
    letter-spacing: 0.12em;
    box-shadow: var(--shadow-xs);
    margin-bottom: 24px;
  }

  h1 {
    font-size: clamp(40px, 6vw, 64px);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin-bottom: 18px;
  }

  p {
    font-size: 17px;
    line-height: 1.55;
    color: var(--color-text-secondary);
    max-width: 480px;
    margin: 0 auto 36px;
  }

  .actions {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
  }

  /*
   * Primary button — dark accent pill. Mirrors the .btn .btn-primary
   * pattern from the original mockup (CLAUDE.md §1 site-wide accent).
   * Sized between .btn (default) and .btn-lg.
   */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 22px;
    background: var(--color-accent);
    color: #fff;
    border: 0.5px solid transparent;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-xs);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.01em;
    transition:
      background 150ms ease-out,
      transform 200ms cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 200ms ease-out;
  }
  .btn-primary:hover {
    background: var(--color-accent-hover);
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
  }

  /* Responsive */
  @media (max-width: 700px) {
    .not-found {
      padding: 100px 24px 120px;
    }
    .actions {
      flex-direction: column;
      width: 100%;
    }
    .btn-primary,
    .actions :global(.btn-ghost-link) {
      width: 100%;
      justify-content: center;
    }
  }
  @media (max-width: 480px) {
    .not-found {
      padding: 72px 20px 96px;
    }
  }
</style>
