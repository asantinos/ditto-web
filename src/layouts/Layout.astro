---
import "../styles/global.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  /**
   * Hide header/footer (e.g. for component preview pages or special layouts).
   */
  bare?: boolean;
}

const {
  title = "Ditto | Voice to text, everywhere you type.",
  description = "Local voice-to-text for Windows. Press a shortcut, speak, and Ditto types into whatever app you're using. 100% local, no account, no cloud.",
  bare = false,
} = Astro.props;

// Absolute URLs required by OG/Twitter crawlers. Astro.site comes from
// astro.config.mjs (https://dittotalks.com).
const ogImage = new URL("/og.png", Astro.site).toString();
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!--
      Favicons. SVG variants are picked by the browser via
      prefers-color-scheme (Chrome 79+, Firefox 79+, Safari 14+). PNG
      fallback uses the same media-query pattern. ICO + apple-touch
      use the light variant as a sensible default since they don't
      switch on color scheme.
    -->
    <link rel="icon" type="image/svg+xml" href="/favicon-light.svg" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/svg+xml" href="/favicon-dark.svg" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/png" href="/favicon-light.png" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/png" href="/favicon-dark.png" media="(prefers-color-scheme: dark)" />
    <link rel="icon" href="/favicon-light.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/favicon-light.png" />

    <meta name="generator" content={Astro.generator} />

    <!-- Auto-discoverable feeds + sitemap -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Ditto Changelog"
      href="/changelog.xml"
    />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Caveat: cursive labels in How-it-works connectors (CLAUDE.md §5.5) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@500&display=swap" rel="stylesheet" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Ditto" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Ditto — Voice typed everywhere." />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    {!bare && <Header />}
    <slot />
    {!bare && <Footer />}

    <!--
      GitHub release & stars fetcher.
      Hydrates: .js-release-version, .js-release-size, .js-release-link[href],
                .js-release-sha, .js-gh-stars
      Cached 5 minutes in localStorage. Falls back silently to hardcoded values.
    -->
    <script>
      (async function fetchLatestRelease() {
        const REPO = "asantinos/ditto";
        const CACHE_KEY = "ditto:gh-release";
        // Bump this whenever stale release data needs to be invalidated for
        // existing visitors. A short TTL keeps new releases visible quickly.
        const CACHE_VERSION = 3;
        const TTL_MS = 5 * 60 * 1000;

        function fmtSize(bytes: number | null | undefined): string | null {
          if (!bytes) return null;
          const mb = bytes / (1024 * 1024);
          return mb >= 1000 ? (mb / 1024).toFixed(2) + " GB" : Math.round(mb) + " MB";
        }
        function fmtStars(n: number | null | undefined): string | null {
          if (n == null) return null;
          if (n < 1000) return String(n);
          if (n < 10000) return (n / 1000).toFixed(1).replace(/\.0$/, "") + "k";
          return Math.round(n / 1000) + "k";
        }

        type ReleaseData = {
          version?: string;
          size?: string;
          url?: string;
          sha?: string;
          stars?: string;
        };

        function apply(data: ReleaseData) {
          if (!data) return;
          const { version, size, url, sha, stars } = data;
          if (version) document.querySelectorAll(".js-release-version").forEach((el) => (el.textContent = version));
          if (size) document.querySelectorAll(".js-release-size").forEach((el) => (el.textContent = size));
          if (url)
            document.querySelectorAll<HTMLAnchorElement>(".js-release-link").forEach((el) => {
              el.setAttribute("href", url);
              el.setAttribute("download", "");
            });
          if (sha) document.querySelectorAll(".js-release-sha").forEach((el) => (el.textContent = sha));
          if (stars) document.querySelectorAll(".js-gh-stars").forEach((el) => (el.textContent = stars));
        }

        try {
          const cached = JSON.parse(localStorage.getItem(CACHE_KEY) || "null");
          if (cached && cached.v === CACHE_VERSION && Date.now() - cached.t < TTL_MS) {
            apply(cached.data);
            return;
          }
        } catch {}

        try {
          const headers = { Accept: "application/vnd.github+json" };
          const [releaseRes, repoRes] = await Promise.all([
            fetch(`https://api.github.com/repos/${REPO}/releases/latest`, { headers }),
            fetch(`https://api.github.com/repos/${REPO}`, { headers }),
          ]);

          const data: ReleaseData = {};

          if (releaseRes.ok) {
            const release = await releaseRes.json();
            const installer = (release.assets || []).find((a: { name: string }) =>
              a.name.toLowerCase().endsWith(".exe"),
            );
            if (installer) {
              data.version = release.tag_name;
              data.size = fmtSize(installer.size) ?? undefined;
              data.url = installer.browser_download_url;
              if (installer.digest && installer.digest.startsWith("sha256:")) {
                data.sha = installer.digest.slice(7);
              }
            }
          }

          if (repoRes.ok) {
            const repo = await repoRes.json();
            data.stars = fmtStars(repo.stargazers_count) ?? undefined;
          }

          if (Object.keys(data).length === 0) throw new Error("Empty response");

          apply(data);
          localStorage.setItem(CACHE_KEY, JSON.stringify({ v: CACHE_VERSION, t: Date.now(), data }));
        } catch (e) {
          console.warn("[ditto] Could not fetch GitHub data:", e);
        }
      })();
    </script>
  </body>
</html>
