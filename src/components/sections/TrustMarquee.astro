// Duplicate for seamless looping (CSS animation translates -50%)
const loopApps = [...apps, ...apps];
---

<div class="trust">
  <div class="trust-text">Works in any app where you can type</div>
  <div class="trust-marquee">
    <div class="trust-marquee-track">
      {
        loopApps.map((app, i) => (
          <div class="trust-app" title={app.name} style={`background: ${app.bg};`} aria-hidden={i >= apps.length}>
            <Fragment set:html={app.svg} />
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  .trust {
    margin: 0 auto 120px;
    text-align: center;
    max-width: 100%;
    padding: 0;
  }
  .trust-text {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 40px;
  }
  .trust-marquee {
    width: 100%;
    overflow: hidden;
    position: relative;
    mask-image: linear-gradient(90deg, transparent 0%, black 6%, black 94%, transparent 100%);
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, black 6%, black 94%, transparent 100%);
    padding: 40px 0 48px;
  }
  .trust-marquee-track {
    display: flex;
    gap: 24px;
    align-items: center;
    width: max-content;
    animation: marquee-scroll 50s linear infinite;
  }
  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(calc(-50% - 12px)); }
  }
  .trust-marquee:hover .trust-marquee-track {
    animation-play-state: paused;
  }
  .trust-app {
    flex-shrink: 0;
    width: 92px;
    height: 92px;
    border-radius: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow:
      0 0 0 0.5px rgba(0, 0, 0, 0.05),
      0 1px 2px rgba(0, 0, 0, 0.04),
      0 8px 24px rgba(0, 0, 0, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 1);
    transition:
      transform 250ms cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 250ms ease-out;
    cursor: pointer;
  }
  .trust-app:hover {
    transform: translateY(-4px) scale(1.05);
    box-shadow:
      0 0 0 0.5px rgba(0, 0, 0, 0.06),
      0 4px 12px rgba(0, 0, 0, 0.08),
      0 16px 40px rgba(0, 0, 0, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 1);
  }
  .trust-app :global(svg) {
    width: 62px;
    height: 62px;
    display: block;
  }

  @media (max-width: 700px) {
    .trust { margin-bottom: 48px; }
    .trust-app {
      width: 76px;
      height: 76px;
      border-radius: 20px;
    }
    .trust-app :global(svg) { width: 50px; height: 50px; }
    .trust-marquee-track { gap: 16px; }
    .trust-marquee { padding: 32px 0 40px; }
  }
  @media (max-width: 480px) {
    .trust { margin-bottom: 36px; }
    .trust-app {
      width: 64px;
      height: 64px;
      border-radius: 16px;
    }
    .trust-app :global(svg) { width: 42px; height: 42px; }
  }
</style>
